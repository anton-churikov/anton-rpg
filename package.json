{
  "name": "anton-rpg",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=22.0.0" },
  "scripts": {
    "build": "cd client && npm install --legacy-peer-deps && npm run build && cd ..",
    "start": "node --experimental-sqlite server/src/index.js",
    "dev:server": "node --watch --experimental-sqlite server/src/index.js",
    "dev:client": "cd client && npm run dev"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
